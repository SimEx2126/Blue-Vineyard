# Copy to .env.local and fill in. .env.local is gitignored — never commit real secrets.

# --- Database ---
# Local dev cluster lives in .pgdata on port 5433 (npm run db:start)
DATABASE_URL=postgres://dev@localhost:5433/adventist_events

# --- Auth (Better Auth) ---
# 32+ char random secret used to sign sessions
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Media storage (Wasabi, S3-compatible) ---
# Event banner uploads are stored here under the adventist-events/ prefix.
# Leave blank to disable uploads (the app still runs; the banner box says so).
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=ap-southeast-2
WASABI_ENDPOINT=https://s3.ap-southeast-2.wasabisys.com
WASABI_BUCKET=adventistcommunityservices
# Wasabi is addressed path-style; leave true unless you know otherwise.
WASABI_FORCE_PATH_STYLE=true

# --- Email (SMTP) ---
# Sends registration confirmations and set-password links. Leave blank and the
# app logs emails to the console instead of sending them.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=
